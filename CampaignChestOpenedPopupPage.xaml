<?xml version="1.0" encoding="utf-8" ?>
<mct:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             x:Class="MazeEscape.CampaignChestOpenedPopupPage"
             CanBeDismissedByTappingOutsideOfPopup="True"
             >
    <Grid RowDefinitions="*">
        <Image Source="background_blue_3.png"
               Aspect="AspectFill"
               Opacity="0.82"/>

        <Border StrokeThickness="0"
                BackgroundColor="#F6F7FB"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Padding="20"
                StrokeShape="RoundRectangle 22"
                WidthRequest="280">
            <VerticalStackLayout Spacing="12">
                <Label Text="Chest Opened"
                       HorizontalOptions="Center"
                       TextColor="#1F2937"
                       FontAttributes="Bold"
                       FontSize="28"/>

                <Label x:Name="coinLabel"
                       HorizontalOptions="Center"
                       TextColor="#0F766E"
                       FontAttributes="Bold"
                       FontSize="30"/>

                <Image x:Name="coinImage"
                       Source="coin.png"
                       HorizontalOptions="Center"
                       WidthRequest="92"
                       HeightRequest="92"
                       Aspect="AspectFit"/>

                <Label Text="Tap outside to continue"
                       HorizontalOptions="Center"
                       TextColor="#4B5563"
                       FontSize="14"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</mct:Popup>