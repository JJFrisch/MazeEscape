# MazeEscape Development Environment Template
# Copy this to .env.local (Git-ignored) and customize for your machine
# Do NOT commit .env.local to version control

# API Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# JWT Configuration
JWT_SIGNING_KEY=your-dev-signing-key-here-replace-in-production
JWT_CLIENT_SECRET=your-dev-client-secret-here
JWT_ISSUER=MazeEscape.Api
JWT_AUDIENCE=MazeEscape.Web
JWT_TOKEN_LIFETIME_MINUTES=30

# Optional: Custom paths (if not using defaults)
# SAVES_FILE_PATH=/custom/path/to/saves.json

# Logging
LOG_LEVEL=Information
