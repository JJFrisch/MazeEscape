<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MazeEscape"
             x:Class="MazeEscape.World2CampaignPage"
             NavigationPage.HasBackButton="False">

    <AbsoluteLayout x:Name="CampaignAbsoluteLayout" Margin="0,-80,0,0"
        Background="AliceBlue">
        <!-- LightSkyBlue -->

        <Image   
        AbsoluteLayout.LayoutBounds="1,0.5,1,1"
        AbsoluteLayout.LayoutFlags="All"
        Source="space_background7.png"
        Aspect="Fill" />

        <Image AbsoluteLayout.LayoutBounds="0,0,1,0.129"
     AbsoluteLayout.LayoutFlags="All"
     Source="space_background12.png"
        Aspect="AspectFill"
     Opacity="0"/> 

        <BoxView AbsoluteLayout.LayoutBounds="5, 7, 375, 70"
                 AbsoluteLayout.LayoutFlags="None"
                 Background="Black"
                 Opacity="0.1"
             CornerRadius="20"/>


        <Label x:Name="starCountLabel"
           FontSize="25" 
           TextColor="White" Text="100"
           VerticalTextAlignment="Center"
           HorizontalTextAlignment="Start"
        AbsoluteLayout.LayoutBounds="65, 0, 150, 80"
        AbsoluteLayout.LayoutFlags="None"/>

        <Image
        Source="full_star.png"
        HorizontalOptions="Start"
        AbsoluteLayout.LayoutBounds="20,0,35,80"
        AbsoluteLayout.LayoutFlags="None"/>

        <Label x:Name="CoinCountLabel"  
           FontSize="25"
           Text="{Binding Name, Source={Static local:App.PlayerData}}"
           TextColor="White"
           VerticalTextAlignment="Center"
           HorizontalTextAlignment="Start"
           AbsoluteLayout.LayoutBounds="210, 0, 150, 80"
           AbsoluteLayout.LayoutFlags="None"/>

        <Image
        Source="coin.png"
        HorizontalOptions="Start"
        AbsoluteLayout.LayoutBounds="165,0,33,85"
        AbsoluteLayout.LayoutFlags="None"/>


        <Image AbsoluteLayout.LayoutBounds="1,1,1,.3"
        AbsoluteLayout.LayoutFlags="All"
        Source="space_background11.png"
           Aspect="AspectFill"
        Opacity="1"/> 


        <ScrollView x:Name="campaignScrollView" Orientation="Horizontal"
                AbsoluteLayout.LayoutBounds="0.5,0.4,1,0.8"
                AbsoluteLayout.LayoutFlags="All"
                Scrolled="OnScrollViewScrolled"
                >

            <AbsoluteLayout x:Name="campaignMazeBackgroundAbsoluteLayout" 
                        WidthRequest="3000">

                <Image AbsoluteLayout.LayoutBounds="1,1,1,1"
               AbsoluteLayout.LayoutFlags="All"
               Source="world2_campaign_background2.png"
               Aspect="Fill"/>


                <Grid x:Name="campaignLevelGrid" 
                Padding="2,0"
                AbsoluteLayout.LayoutBounds="0,0,1,1"
                AbsoluteLayout.LayoutFlags="All"
                ColumnDefinitions="*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*" 
                RowDefinitions="*,*,*,*,*,*"
                  ZIndex="1">
                    <!-- 40 cols by 6 rows-->

                    

                </Grid>

                <!-- Gates, Gate Labels, Fogs-->

                
                
                <ImageButton x:Name="gateImage1"
       AbsoluteLayout.LayoutBounds="18,273,35,80"
       AbsoluteLayout.LayoutFlags="None"
       Aspect="AspectFit"
       Source="world2_gate.png"
       Rotation="270"
       Clicked="OnLockedGateImageButtonClicked"
         Background="Transparent"/>

                <Label x:Name="gateLabel1"
       AbsoluteLayout.LayoutBounds="32.5,304.5,20,20"
       AbsoluteLayout.LayoutFlags="None"
       Text="20"
       FontSize="12"
       TextColor="White"
       FontAttributes="Bold"/>                
                
                <ImageButton x:Name="gateImage2"
       AbsoluteLayout.LayoutBounds="167,41,35,80"
       AbsoluteLayout.LayoutFlags="None"
       Aspect="AspectFit"
       Source="world2_gate.png"
       Rotation="270"
       Clicked="OnLockedGateImageButtonClicked"
         Background="Transparent"/>

                <Label x:Name="gateLabel2"
       AbsoluteLayout.LayoutBounds="180.5,72,20,20"
       AbsoluteLayout.LayoutFlags="None"
       Text="20"
       FontSize="12"
       TextColor="White"
       FontAttributes="Bold"/>            
                
                <ImageButton x:Name="gateImage3"
       AbsoluteLayout.LayoutBounds="317,191,35,80"
       AbsoluteLayout.LayoutFlags="None"
       Aspect="AspectFit"
       Source="world2_gate.png"
       Rotation="90"
       Clicked="OnLockedGateImageButtonClicked"
         Background="Transparent"/>

                <Label x:Name="gateLabel3"
       AbsoluteLayout.LayoutBounds="332.5,222.5,20,20"
       AbsoluteLayout.LayoutFlags="None"
       Text="20"
       FontSize="12"
       TextColor="White"
       FontAttributes="Bold"/>





                <ImageButton x:Name="fog_area_1_image"
       AbsoluteLayout.LayoutBounds="1,0.5,2324,470"
       AbsoluteLayout.LayoutFlags="PositionProportional"
       Aspect="Fill"
       IsVisible="False"
       Background="Transparent"
       Opacity="0.9"
       Source="fog_stage_1.png"
                         ZIndex="5"/>

            </AbsoluteLayout>

        </ScrollView>


        <Image Source="pointer_arrow.png" x:Name="startingArrow"
            AbsoluteLayout.LayoutBounds="200, 330, 100, 100"
            AbsoluteLayout.LayoutFlags="None"
            IsVisible="False" />


        <BoxView AbsoluteLayout.LayoutBounds="0.5,0.983,0.85,75"
                 AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional"
                 BackgroundColor="Black"
                 Opacity="0.6"
                 CornerRadius="10,10,10,10"/>



        <ImageButton Source="toolkit.png"
         AbsoluteLayout.LayoutBounds="0.205,0.982,40,75"
         AbsoluteLayout.LayoutFlags="PositionProportional"
         Clicked="OnEquipButtonClicked"
                 Background="Transparent">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="Scale"
                Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity"
                    Value="0.6" />
                                <Setter Property="Scale"
                    Value="0.95" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Opacity"
                    Value="0.75" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </VisualStateManager.VisualStateGroups>
        </ImageButton>

        <ImageButton Source="home_button_icon.png"
         AbsoluteLayout.LayoutBounds="0.5,0.982,55,70"
         AbsoluteLayout.LayoutFlags="PositionProportional"
         Clicked="BackButton_Clicked"
                 Background="Transparent">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="Scale"
                Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity"
                    Value="0.6" />
                                <Setter Property="Scale"
                    Value="0.95" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Opacity"
                    Value="0.8" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </VisualStateManager.VisualStateGroups>
        </ImageButton>

        <ImageButton x:Name="shopButton" Clicked="OnShopButtonClicked"  
                    AbsoluteLayout.LayoutBounds="0.8,0.982,50,70"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    Source="shop_button_image.png"
                 Background="Transparent">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="Scale"
                Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity"
                    Value="0.4" />
                                <Setter Property="Scale"
                    Value="0.95" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Opacity"
                    Value="0.7" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </VisualStateManager.VisualStateGroups>
        </ImageButton>




    </AbsoluteLayout>

</ContentPage>